# ============================================================
# TRADER REHAB — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local dans git
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- OpenAI (analyse IA comportementale) ---
OPENAI_API_KEY=sk-proj-...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TraderRehab

# --- Sécurité ---
# Clé secrète pour les API routes internes (générer avec: openssl rand -hex 32)
API_SECRET_KEY=change_me_with_random_hex_string

# --- Feature flags ---
NEXT_PUBLIC_ENABLE_AI_ANALYSIS=true
NEXT_PUBLIC_ENABLE_PDF_EXPORT=true
NEXT_PUBLIC_ENABLE_BACKTEST=false
